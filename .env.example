# OpenAI API Configuration
OPENAI_API_KEY=secret-key
OPENAI_BASE_URL=https://any-openai-compatible-api.com/v1

# LiteLLM Configuration
LITELLM_MASTER_KEY=secret-api-key

# Database Configuration
POSTGRES_USER=mts_user
POSTGRES_PASSWORD=mts_password
POSTGRES_DB=mts_agentic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=secret-api-key

# Mem0 Configuration
MEM0_COLLECTION_NAME=mts_memories

# E2B Configuration
E2B_API_KEY=

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# LangGraph Configuration
LANGGRAPH_RECURSION_LIMIT=50
MAX_QA_ITERATIONS=3